# AegisDesk environment template
#
# Default values support a local evaluation build. For a customer-facing
# deployment, set NEXT_PUBLIC_AEGISDESK_MODE=production and disable persona
# issuance with AEGISDESK_PERSONA_ISSUER_ENABLED=false.

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AEGISDESK_MODE=evaluation
NEXT_PUBLIC_SHOW_EVALUATION_TOOLS=true

# API auth mode: hmac for local evaluation, jwks for local RS256, cognito for AWS.
AEGISDESK_AUTH_MODE=hmac
AEGISDESK_AUTH_SECRET=replace-with-local-dev-secret
AEGISDESK_PERSONA_ISSUER_ENABLED=true
AEGISDESK_PERSONA_AUTH_ENABLED=true
AEGISDESK_PERSONA_PASSWORD_SEED=replace-with-non-production-seed

# Cognito / JWKS production identity.
AEGISDESK_COGNITO_USER_POOL_ID=
AEGISDESK_COGNITO_CLIENT_ID=
AEGISDESK_COGNITO_HOSTED_UI_DOMAIN=
AEGISDESK_COGNITO_REGION=us-east-1
AEGISDESK_JWKS_PRIVATE_KEY_PEM=
AEGISDESK_JWKS_PUBLIC_KEY_PEM=
AEGISDESK_JWKS_KEY_ID=aegisdesk-local-rs256
AEGISDESK_JWT_ISSUER=aegisdesk-local
AEGISDESK_JWT_AUDIENCE=

# Policy and observability.
AEGISDESK_POLICY_MODE=auto
OPA_URL=http://localhost:8181
AEGISDESK_OPA_EXECUTABLE=
AEGISDESK_OPA_POLICY_PATH=
AEGISDESK_OPA_TIMEOUT_SECONDS=0.75
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=aegisdesk-api

# Data store.
AEGISDESK_STORE_BACKEND=sqlite
AEGISDESK_DB_PATH=data/aegisdesk.db
AEGISDESK_DYNAMODB_TABLE=

# AWS runtime.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AEGISDESK_ENABLE_BEDROCK=false
AEGISDESK_BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
AEGISDESK_BEDROCK_MAX_TOKENS=180
AEGISDESK_BEDROCK_TIMEOUT_SECONDS=8
AEGISDESK_BEDROCK_INPUT_PRICE_PER_1M_TOKENS=0.06
AEGISDESK_BEDROCK_OUTPUT_PRICE_PER_1M_TOKENS=0.24

# Cost governance.
AEGISDESK_ENABLE_COST_EXPLORER=false
AEGISDESK_COST_CACHE_TTL_SECONDS=21600
AEGISDESK_COST_EXPLORER_SCOPE=tagged
AEGISDESK_COST_EXPLORER_TAG_KEY=Project
AEGISDESK_COST_EXPLORER_TAG_VALUE=AegisDesk

# Ticketing integration. Use local for evaluation or jira for a paid pilot.
AEGISDESK_TICKET_ADAPTER=local
AEGISDESK_JIRA_BASE_URL=
AEGISDESK_JIRA_EMAIL=
AEGISDESK_JIRA_API_TOKEN=
AEGISDESK_JIRA_PROJECT_KEY=
AEGISDESK_JIRA_ISSUE_TYPE=Task
AEGISDESK_JIRA_TIMEOUT_SECONDS=8
AEGISDESK_SERVICENOW_INSTANCE_URL=
AEGISDESK_SERVICENOW_USERNAME=
AEGISDESK_SERVICENOW_PASSWORD=
AEGISDESK_SERVICENOW_ASSIGNMENT_GROUP=
AEGISDESK_SERVICENOW_TABLE=incident
AEGISDESK_SERVICENOW_TIMEOUT_SECONDS=8

# Incident context integration. Use local_fixture for sample logs or cloudwatch for real CloudWatch Logs Insights.
AEGISDESK_INCIDENT_CONTEXT_ADAPTER=local_fixture
AEGISDESK_CLOUDWATCH_LOG_GROUP=
AEGISDESK_CLOUDWATCH_LOGS_REGION=us-east-1
AEGISDESK_CLOUDWATCH_QUERY_LOOKBACK_MINUTES=60
AEGISDESK_CLOUDWATCH_QUERY_LIMIT=20
AEGISDESK_CLOUDWATCH_QUERY_POLL_ATTEMPTS=6
AEGISDESK_CLOUDWATCH_QUERY_POLL_INTERVAL_SECONDS=0.5

# Audit retention and export controls.
AEGISDESK_AUDIT_RETENTION_DAYS=30
AEGISDESK_AUDIT_EXPORT_MAX_EVENTS=500

# Abuse and cost controls.
AEGISDESK_QUOTA_WINDOW_SECONDS=86400
AEGISDESK_MAX_REQUEST_CHARS=2000
AEGISDESK_CLOUD_MODEL_KILL_SWITCH=false
AEGISDESK_API_THROTTLE_RATE_LIMIT=5
AEGISDESK_API_THROTTLE_BURST_LIMIT=20

# Browser/API boundary.
AEGISDESK_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local model configuration.
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3.1

# Optional cloud provider key for local experiments. The app does not require it.
OPENAI_API_KEY=

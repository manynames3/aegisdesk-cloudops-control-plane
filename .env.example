# Optional cloud model provider key.
# The app should run without this by using local or deterministic fallback routes.
OPENAI_API_KEY=

# Local model configuration.
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3.1

# OPA and observability.
AEGISDESK_POLICY_MODE=auto
OPA_URL=http://localhost:8181
AEGISDESK_OPA_TIMEOUT_SECONDS=0.75
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=aegisdesk-api

# Portfolio persona issuer for local reviewer workflows.
AEGISDESK_PERSONA_ISSUER_ENABLED=true
AEGISDESK_AUTH_SECRET=replace-with-local-dev-secret

# Local SQLite audit/event store. Use :memory: for non-persistent runs.
AEGISDESK_DB_PATH=data/aegisdesk.db
